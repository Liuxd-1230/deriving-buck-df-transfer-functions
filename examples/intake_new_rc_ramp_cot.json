{
  "similar_model": "cot-cm-external-ramp-tian-2015",
  "modifications": ["external ramp is generated by an RC network rather than a linear source"],
  "topology": "buck",
  "conduction_mode": "CCM",
  "phases": 1,
  "control_family": "external-ramp-cot-current-mode",
  "target": "Gvc",
  "control_timing": {"fixed": "Ton", "variable": "Toff/Tsw"},
  "state_variables": ["iL", "vo", "vramp"],
  "switching_state_equations": {"on": "L*diL/dt=vg-vo; tau_r*dvramp/dt=Vr-vramp", "off": "L*diL/dt=-vo; tau_r*dvramp/dt=-vramp"},
  "steady_state_trajectory": "piecewise CCM current and periodic RC ramp; solve continuity before perturbation",
  "switching_events": [{
    "name": "off_edge",
    "fixed_or_movable": "movable",
    "equation": "F_off=Ri*iL(t_off)+vramp(t_off)-vc=0",
    "edge_slope": "Fdot_0=Ri*diL_0/dt+dvramp_0/dt",
    "delta_edge": "delta_t_off=-delta_F/Fdot_0"
  }],
  "comparator_inputs": {"positive": "vc", "negative": "Ri*iL+vramp"},
  "parameters": {"Vin": 12.0, "Vo": 1.2, "fs": 300000.0, "L": 3e-7, "C": 0.00047, "R": 0.1, "rC": 0.001, "Ri": 0.01, "tau_r": 1e-6},
  "perturbation_paths": {"uc_hat": "direct event input", "iL_hat": "current-sense path", "vo_hat": "power stage and RC trajectory"},
  "df_relation": {
    "form": "d_hat=a_c(s)*uc_hat+a_g(s)*vg_hat+a_o(s)*vo_hat+a_i(s)*iL_hat",
    "a_c": "derive from periodic RC event recurrence",
    "a_g": "derive from trajectory sensitivity",
    "a_o": "derive from trajectory sensitivity",
    "a_i": "derive from current-sense event sensitivity",
    "origin": "paper-inspired-new-derivation",
    "duty_caveat": "d_hat is an equivalent switching-function perturbation, not assumed low-frequency duty"
  },
  "sanity_checks": ["symbolic", "dc-limit"],
  "validation_missing": ["paper-benchmark", "switching-simulation"]
}
