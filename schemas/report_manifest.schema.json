{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ESSF v0.4 report manifest",
  "type": "object",
  "required": ["report_version", "case_id"],
  "properties": {
    "report_version": {"const": "0.4"},
    "case_id": {"type": "string"},
    "report": {"type": "string"},
    "report_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["path", "purpose"],
            "properties": {
              "path": {"type": "string"},
              "purpose": {"type": "string"},
              "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
            }
          }
        ]
      }
    },
    "workflow": {
      "type": "object",
      "properties": {"version": {"const": "0.4"}, "state": {"const": "REPORT"}},
      "required": ["version", "state", "artifact_sha256"]
    }
  },
  "anyOf": [
    {"required": ["report", "artifacts"]},
    {"required": ["format", "markdown_sha256", "source_derivation_sha256", "source_checker_sha256", "workflow"]}
  ]
}
