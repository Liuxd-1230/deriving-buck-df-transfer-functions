{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ESSF derivation artifact",
  "$defs": {
    "workflow": {
      "type": "object",
      "required": ["version", "intent", "state", "history", "predecessor", "artifact_sha256"],
      "properties": {
        "version": {"const": "0.4"},
        "state": {"const": "DERIVATION"}
      }
    },
    "derivation_step": {
      "type": "object",
      "required": ["step_id", "title", "latex", "explanation", "source_artifact", "latex_origin", "provenance"],
      "properties": {
        "step_id": {"type": "string"},
        "title": {"type": "string"},
        "latex": {"type": "string"},
        "explanation": {"type": "string"},
        "source_artifact": {
          "enum": ["linear_equation_system.json", "derivation.json", "formula_registry.yaml"]
        },
        "latex_origin": {
          "enum": ["solver_generated", "registry_binding", "user_supplied_diagnostic"]
        },
        "provenance": {"type": "string"}
      }
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["derivation_version", "case_id", "workflow", "classification", "control_contract", "selected_loop", "target_transfer", "target_formula_id", "response_kind", "expressions", "expanded_expressions", "expanded_target_expression", "numeric_expanded_expressions", "numeric_expanded_target_expression", "reasoning_method", "steps", "approximation_policy", "validation"],
      "properties": {
        "derivation_version": {"const": "0.4"},
        "workflow": {"$ref": "#/$defs/workflow"},
        "control_contract": {"enum": ["current", "voltage"]},
        "selected_loop": {"enum": ["Ti", "Tv"]},
        "response_kind": {"enum": ["return_ratio", "transfer_function", "closed_loop"]},
        "expressions": {"type": "object"},
        "numeric_expanded_expressions": {"type": "object"},
        "numeric_expanded_target_expression": {"type": "string"},
        "reasoning_method": {"type": "object"},
        "steps": {
          "type": "array",
          "minItems": 7,
          "items": {
            "type": "object",
            "required": ["index", "object", "formula_id", "expression", "source_equation", "approximation", "dimension_signature"]
          }
        },
        "derivation_steps": {
          "type": "array",
          "items": {"$ref": "#/$defs/derivation_step"}
        },
        "approximation_policy": {"type": "object", "required": ["declared", "items", "valid_frequency"]}
      }
    },
    {
      "type": "object",
      "required": ["derivation_version", "case_id", "classification", "target_transfer", "response_kind", "target", "linear_equation_system", "generated_by", "generated_expression", "expanded_target_expression", "expressions", "reasoning_method", "steps", "derivation_steps", "elimination_metadata", "denominator_provenance", "approximation_policy", "validation"],
      "properties": {
        "derivation_version": {"const": "0.4.5"},
        "workflow": {"$ref": "#/$defs/workflow"},
        "classification": {"type": "object"},
        "target_transfer": {"type": "string"},
        "response_kind": {"enum": ["transfer_function", "return_ratio", "closed_loop"]},
        "target": {
          "type": "object",
          "required": ["name", "output", "input", "response_kind"]
        },
        "linear_equation_system": {"type": "object"},
        "generated_by": {"const": "linear_system_transfer.py"},
        "generated_expression": {"type": "string"},
        "expanded_target_expression": {"type": "string"},
        "expressions": {"type": "object"},
        "reasoning_method": {"type": "object"},
        "steps": {"type": "array"},
        "derivation_steps": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/derivation_step"}
        },
        "elimination_metadata": {
          "type": "object",
          "required": ["active_equations", "diagnostic_equations", "eliminated_variables", "block_trace"]
        },
        "denominator_provenance": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["factor_or_term", "source_equations", "feedback_path", "generated_by_solver"],
            "properties": {
              "factor_or_term": {"type": "string"},
              "source_equations": {"type": "array", "items": {"type": "string"}},
              "feedback_path": {"type": "string"},
              "generated_by_solver": {"const": true}
            }
          }
        },
        "approximation_policy": {"type": "object", "required": ["declared", "items", "valid_frequency"]},
        "validation": {"type": "object", "required": ["level", "completed", "missing"]}
      }
    }
  ]
}
