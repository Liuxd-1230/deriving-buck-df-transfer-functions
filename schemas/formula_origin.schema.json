{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["source", "formula_ids", "formulas", "handwritten_formula_variants"],
  "properties": {
    "source": {"const": "formula_registry.yaml"},
    "formula_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "formulas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "formula_id",
          "source_model_id",
          "interface",
          "canonical_sympy_expr",
          "dimension_signature",
          "numeric_probe_values",
          "source_equation",
          "approximation"
        ],
        "properties": {
          "formula_id": {"type": "string"},
          "source_model_id": {"type": "string"},
          "interface": {"type": "string"},
          "canonical_sympy_expr": {"type": "string"},
          "dimension_signature": {"type": "string"},
          "numeric_probe_values": {"type": "object"},
          "source_equation": {"type": "string"},
          "approximation": {"type": "string"}
        }
      }
    },
    "handwritten_formula_variants": {"const": false}
  }
}
